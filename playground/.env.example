# -----------------------------------------------------------------------------
# ZITADEL OpenID Connect (OIDC) Configuration
# -----------------------------------------------------------------------------
# This is a CLIENT-SIDE Angular SPA using the Authorization Code Flow with PKCE.
# Every value below is compiled into the browser bundle (the NG_APP_ prefix is
# what makes @ngx-env/builder expose it to the app), so NONE of them are
# secret. A public PKCE client does NOT use a client secret — do not add one.

# The full domain URL of your ZITADEL instance, used as the OIDC `authority`.
# Example: https://my-org-a1b2c3.zitadel.cloud
NG_APP_ZITADEL_DOMAIN="https://your-zitadel-domain"

# The Client ID of your ZITADEL application (Application type: User Agent / SPA
# with the PKCE auth method).
NG_APP_ZITADEL_CLIENT_ID="your-zitadel-application-client-id"

# The URL ZITADEL redirects back to after authentication. This MUST exactly
# match one of the "Redirect URIs" configured on your ZITADEL application.
NG_APP_ZITADEL_REDIRECT_URI="http://localhost:4200/auth/callback"

# The URL ZITADEL redirects to after logout. This MUST exactly match one of the
# "Post Logout Redirect URIs" configured on your ZITADEL application.
NG_APP_ZITADEL_POST_LOGOUT_REDIRECT_URI="http://localhost:4200/auth/logout/callback"

# The OIDC scopes requested at sign-in. Defaults to "openid profile email".
NG_APP_ZITADEL_SCOPE="openid profile email"
