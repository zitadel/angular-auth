{
  "name": "@zitadel/angular-auth",
  "description": "A comprehensive authentication integration for Angular applications with TypeScript support, PKCE-based OIDC, and session management",
  "version": "3.0.0",
  "type": "module",
  "main": "dist/public-api.js",
  "types": "dist/public-api.d.ts",
  "exports": {
    ".": {
      "types": "./dist/public-api.d.ts",
      "import": "./dist/public-api.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zitadel/angular-auth.git"
  },
  "author": {
    "name": "Mridang Agarwalla",
    "email": "mridang@zitadel.com",
    "url": "https://github.com/zitadel"
  },
  "scripts": {
    "prepack": "ngc -p tsconfig.json",
    "test": "npm run test:unit",
    "test:unit": "jest --verbose --config=jest.config.mjs --runInBand --passWithNoTests",
    "test:watch": "npm run test:unit -- --watch",
    "typecheck": "tsc --noEmit",
    "test:debug": "jest --verbose --config=jest.config.mjs --runInBand --detectOpenHandles",
    "prepare": "npm run build",
    "build": "ngc -p tsconfig.json",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "npx eslint . --fix",
    "depcheck": "npx knip",
    "docs": "typedoc"
  },
  "peerDependencies": {
    "@angular/common": ">=18.0.0",
    "@angular/core": ">=18.0.0",
    "@angular/router": ">=18.0.0",
    "oidc-client-ts": ">=3.0.0",
    "rxjs": ">=7.0.0"
  },
  "devDependencies": {
    "@angular/common": "^21.2.15",
    "@angular/compiler": "^21.2.15",
    "@angular/compiler-cli": "^21.2.15",
    "@angular/core": "^21.2.15",
    "@angular/router": "^21.2.15",
    "@commitlint/config-conventional": "^21.0.2",
    "@jest/globals": "^30.0.5",
    "@mridang/eslint-defaults": "^1.6.1",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.0",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@tsconfig/node22": "^22.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.1",
    "eslint": "10.4.1",
    "jest": "30.4.2",
    "jest-environment-jsdom": "30.4.1",
    "jest-junit": "^17.0.0",
    "knip": "^6.14.2",
    "oidc-client-ts": "^3.4.0",
    "prettier": "3.8.3",
    "rxjs": "^7.8.0",
    "semantic-release": "^25.0.3",
    "ts-jest": "29.4.11",
    "typedoc": "^0.28.7",
    "typescript": "~6.0.3",
    "zone.js": "^0.16.2"
  },
  "keywords": [
    "auth",
    "authentication",
    "authorization",
    "authn",
    "authz",
    "oauth",
    "oidc",
    "jwt",
    "jwks",
    "pkce",
    "angular"
  ],
  "private": false,
  "homepage": "https://github.com/zitadel/angular-auth",
  "bugs": "https://github.com/zitadel/angular-auth/issues",
  "publishConfig": {
    "access": "public"
  }
}
